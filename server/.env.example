# Server Configuration
NODE_ENV=production
PORT=5000

# Database (MongoDB Atlas)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/alpha-freshman-tutorial

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=30d

# ── Email — Option A: Resend.com (recommended, free tier 3000/month) ──────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@yourdomain.com

# ── Email — Option B: Gmail SMTP ──────────────────────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=yourname@gmail.com
# SMTP_PASS=xxxx xxxx xxxx xxxx   ← Gmail App Password (not your real password)
# EMAIL_FROM=yourname@gmail.com

# Frontend URL
CLIENT_URL=https://alpha-freshman-tutorial.vercel.app

# Chapa Payment (Ethiopian gateway)
CHAPA_SECRET_KEY=CHASECK_TEST-xxxxxxxxxxxx

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
